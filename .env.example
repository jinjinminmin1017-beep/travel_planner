# Official-airline sources remain fail-closed. ENV may configure transport and
# governance but cannot claim request-schema implementation readiness.
TRAVEL_SOURCE_AIRLINE_MU_PUBLIC_QUERY_ADAPTER=official_airline_public_query
TRAVEL_SOURCE_AIRLINE_MU_PUBLIC_QUERY_ENABLED=false
