# AI Travel Planner real API configuration
# Copy to .env or set these variables in your shell before starting the backend.

APP_ENV=DEV

# Persistence and cache
# DEV defaults to local SQLite for restart-safe snapshots. Production can set
# TRAVEL_PERSISTENCE_BACKEND=postgres after packaging psycopg and providing POSTGRES_DSN.
TRAVEL_PERSISTENCE_BACKEND=sqlite
TRAVEL_SQLITE_PATH=logs/travel_planner.sqlite3
POSTGRES_DSN=
REDIS_URL=
TRAVEL_CACHE_ASYNC_JOB_TTL_SECONDS=1800
TRAVEL_CACHE_RECALCULATE_TTL_SECONDS=900
TRAVEL_ASYNC_JOB_TIMEOUT_SECONDS=30
TRAVEL_PROVIDER_TIMEOUT_SECONDS=10
TRAVEL_PROVIDER_RETRY_COUNT=1
TRAVEL_MAX_CONCURRENT_JOBS=4
TRAVEL_REQUIRE_API_KEY=false
TRAVEL_API_KEY=
TRAVEL_MAX_BODY_BYTES=65536
TRAVEL_API_RATE_LIMIT_PER_MINUTE=60
TRAVEL_LOG_FILE_ENABLED=true
TRAVEL_LOG_DIR=logs
TRAVEL_LOG_FILE_PREFIX=backend
TRAVEL_LOG_LEVEL=INFO
TRAVEL_LOG_MAX_BYTES=104857600

# Internal deterministic source
TRAVEL_SOURCE_INTERNAL_CALC_ENABLED=true
TRAVEL_SOURCE_INTERNAL_CALC_LICENSE_STATUS=APPROVED
TRAVEL_SOURCE_INTERNAL_CALC_QPS_LIMIT=1000
TRAVEL_SOURCE_INTERNAL_CALC_COMMERCIAL_ALLOWED=false

# Map route providers
TRAVEL_SOURCE_AMAP_ROUTE_ENABLED=false
TRAVEL_SOURCE_AMAP_ROUTE_LICENSE_STATUS=PENDING_REVIEW
TRAVEL_SOURCE_AMAP_ROUTE_QPS_LIMIT=0
TRAVEL_SOURCE_AMAP_ROUTE_COMMERCIAL_ALLOWED=false
AMAP_WEB_SERVICE_KEY=

# AMap address geocoding and POI search reuse AMAP_WEB_SERVICE_KEY but remain
# independently switchable for capability governance and observability.
TRAVEL_SOURCE_AMAP_GEOCODE_ENABLED=false
TRAVEL_SOURCE_AMAP_GEOCODE_LICENSE_STATUS=PENDING_REVIEW
TRAVEL_SOURCE_AMAP_GEOCODE_QPS_LIMIT=0
TRAVEL_SOURCE_AMAP_GEOCODE_COMMERCIAL_ALLOWED=false
TRAVEL_SOURCE_AMAP_PLACE_SEARCH_ENABLED=false
TRAVEL_SOURCE_AMAP_PLACE_SEARCH_LICENSE_STATUS=PENDING_REVIEW
TRAVEL_SOURCE_AMAP_PLACE_SEARCH_QPS_LIMIT=0
TRAVEL_SOURCE_AMAP_PLACE_SEARCH_COMMERCIAL_ALLOWED=false
AMAP_GEOCODING_BASE_URL=https://restapi.amap.com

TRAVEL_SOURCE_BAIDU_MAP_ROUTE_ENABLED=false
TRAVEL_SOURCE_BAIDU_MAP_ROUTE_LICENSE_STATUS=PENDING_REVIEW
TRAVEL_SOURCE_BAIDU_MAP_ROUTE_QPS_LIMIT=0
TRAVEL_SOURCE_BAIDU_MAP_ROUTE_COMMERCIAL_ALLOWED=false
BAIDU_MAP_AK=

# Optional no-key route provider for read-only route smoke and development.
# For production usage, run your own OSRM service or use an approved commercial map provider.
TRAVEL_SOURCE_OSRM_ROUTE_ENABLED=true
TRAVEL_SOURCE_OSRM_ROUTE_LICENSE_STATUS=APPROVED
TRAVEL_SOURCE_OSRM_ROUTE_QPS_LIMIT=1
TRAVEL_SOURCE_OSRM_ROUTE_COMMERCIAL_ALLOWED=false
OSRM_ROUTE_BASE_URL=https://router.project-osrm.org

# Optional no-key geocoding provider for read-only location resolution.
# Public Nominatim usage requires a descriptive User-Agent and low-frequency calls.
TRAVEL_SOURCE_NOMINATIM_GEOCODE_ENABLED=true
TRAVEL_SOURCE_NOMINATIM_GEOCODE_LICENSE_STATUS=APPROVED
TRAVEL_SOURCE_NOMINATIM_GEOCODE_QPS_LIMIT=1
TRAVEL_SOURCE_NOMINATIM_GEOCODE_COMMERCIAL_ALLOWED=false
NOMINATIM_BASE_URL=https://nominatim.openstreetmap.org
NOMINATIM_USER_AGENT=AITravelPlanner/0.1 (local-dev)

# Map redirect providers
TRAVEL_SOURCE_AMAP_URI_REDIRECT_ENABLED=true
TRAVEL_SOURCE_AMAP_URI_REDIRECT_LICENSE_STATUS=APPROVED
TRAVEL_SOURCE_AMAP_URI_REDIRECT_QPS_LIMIT=1
TRAVEL_SOURCE_AMAP_URI_REDIRECT_COMMERCIAL_ALLOWED=false

TRAVEL_SOURCE_BAIDU_URI_REDIRECT_ENABLED=false
TRAVEL_SOURCE_BAIDU_URI_REDIRECT_LICENSE_STATUS=PENDING_REVIEW
TRAVEL_SOURCE_BAIDU_URI_REDIRECT_QPS_LIMIT=0
TRAVEL_SOURCE_BAIDU_URI_REDIRECT_COMMERCIAL_ALLOWED=false

# Flight official public frontend harvesting.
# Disabled by default until each source passes ToS/robots/compliance review.
# No login, captcha bypass, strong-auth bypass, order, payment, or ticket grabbing.
TRAVEL_FLIGHT_SNAPSHOT_BACKEND=sqlite
TRAVEL_FLIGHT_SNAPSHOT_SQLITE_PATH=logs/flight_harvest.sqlite3

TRAVEL_SOURCE_AIRLINE_MU_PUBLIC_QUERY_ENABLED=false
TRAVEL_SOURCE_AIRLINE_MU_PUBLIC_QUERY_LICENSE_STATUS=PENDING_REVIEW
TRAVEL_SOURCE_AIRLINE_MU_PUBLIC_QUERY_QPS_LIMIT=0
TRAVEL_SOURCE_AIRLINE_MU_PUBLIC_QUERY_COMMERCIAL_ALLOWED=false
TRAVEL_SOURCE_AIRLINE_MU_PUBLIC_QUERY_BASE_URL=
TRAVEL_SOURCE_AIRLINE_MU_PUBLIC_QUERY_SEARCH_PATH=/api/flight/search
TRAVEL_SOURCE_AIRLINE_MU_PUBLIC_QUERY_USER_AGENT=AITravelPlanner/0.1 public-airline-query
TRAVEL_SOURCE_AIRLINE_MU_PUBLIC_QUERY_CACHE_TTL_SECONDS=60

TRAVEL_SOURCE_AIRLINE_CZ_PUBLIC_QUERY_ENABLED=false
TRAVEL_SOURCE_AIRLINE_CZ_PUBLIC_QUERY_LICENSE_STATUS=PENDING_REVIEW
TRAVEL_SOURCE_AIRLINE_CZ_PUBLIC_QUERY_QPS_LIMIT=0
TRAVEL_SOURCE_AIRLINE_CZ_PUBLIC_QUERY_COMMERCIAL_ALLOWED=false
TRAVEL_SOURCE_AIRLINE_CZ_PUBLIC_QUERY_BASE_URL=
TRAVEL_SOURCE_AIRLINE_CZ_PUBLIC_QUERY_SEARCH_PATH=/api/flight/search
TRAVEL_SOURCE_AIRLINE_CZ_PUBLIC_QUERY_USER_AGENT=AITravelPlanner/0.1 public-airline-query
TRAVEL_SOURCE_AIRLINE_CZ_PUBLIC_QUERY_CACHE_TTL_SECONDS=60

TRAVEL_SOURCE_AIRLINE_SC_PUBLIC_QUERY_ENABLED=false
TRAVEL_SOURCE_AIRLINE_SC_PUBLIC_QUERY_LICENSE_STATUS=PENDING_REVIEW
TRAVEL_SOURCE_AIRLINE_SC_PUBLIC_QUERY_QPS_LIMIT=0
TRAVEL_SOURCE_AIRLINE_SC_PUBLIC_QUERY_COMMERCIAL_ALLOWED=false
TRAVEL_SOURCE_AIRLINE_SC_PUBLIC_QUERY_BASE_URL=
TRAVEL_SOURCE_AIRLINE_SC_PUBLIC_QUERY_SEARCH_PATH=/api/flight/search
TRAVEL_SOURCE_AIRLINE_SC_PUBLIC_QUERY_USER_AGENT=AITravelPlanner/0.1 public-airline-query
TRAVEL_SOURCE_AIRLINE_SC_PUBLIC_QUERY_CACHE_TTL_SECONDS=60

# Optional no-key flight state provider for read-only live aircraft states.
# This is not a ticket pricing provider and must not be used as a fare source.
TRAVEL_SOURCE_OPENSKY_STATES_ENABLED=true
TRAVEL_SOURCE_OPENSKY_STATES_LICENSE_STATUS=APPROVED
TRAVEL_SOURCE_OPENSKY_STATES_QPS_LIMIT=1
TRAVEL_SOURCE_OPENSKY_STATES_COMMERCIAL_ALLOWED=false
OPENSKY_BASE_URL=https://opensky-network.org

# Optional no-key weather provider for read-only weather/risk data.
# This is not a fare, availability, or traffic source.
TRAVEL_SOURCE_OPEN_METEO_FORECAST_ENABLED=true
TRAVEL_SOURCE_OPEN_METEO_FORECAST_LICENSE_STATUS=APPROVED
TRAVEL_SOURCE_OPEN_METEO_FORECAST_QPS_LIMIT=1
TRAVEL_SOURCE_OPEN_METEO_FORECAST_COMMERCIAL_ALLOWED=false
OPEN_METEO_BASE_URL=https://api.open-meteo.com

# Flight status / risk provider
TRAVEL_SOURCE_VARIFLIGHT_STATUS_ENABLED=false
TRAVEL_SOURCE_VARIFLIGHT_STATUS_LICENSE_STATUS=PENDING_REVIEW
TRAVEL_SOURCE_VARIFLIGHT_STATUS_QPS_LIMIT=0
TRAVEL_SOURCE_VARIFLIGHT_STATUS_COMMERCIAL_ALLOWED=false
VARIFLIGHT_API_KEY=

# 12306 public anonymous query. No login, captcha bypass, order, payment, or ticket grabbing.
TRAVEL_SOURCE_RAIL_12306_PUBLIC_QUERY_ENABLED=true
TRAVEL_SOURCE_RAIL_12306_PUBLIC_QUERY_LICENSE_STATUS=APPROVED
TRAVEL_SOURCE_RAIL_12306_PUBLIC_QUERY_QPS_LIMIT=1
TRAVEL_SOURCE_RAIL_12306_PUBLIC_QUERY_MIN_INTERVAL_SECONDS=1
TRAVEL_SOURCE_RAIL_12306_PUBLIC_QUERY_CACHE_TTL_SECONDS=60
TRAVEL_SOURCE_RAIL_12306_PUBLIC_QUERY_COMMERCIAL_ALLOWED=false
TRAVEL_SOURCE_RAIL_12306_PUBLIC_QUERY_BASE_URL=https://kyfw.12306.cn
TRAVEL_SOURCE_RAIL_12306_PUBLIC_QUERY_USER_AGENT=AITravelPlanner/0.1 public-12306-query

# Rail connection matcher policy. Invalid values fall back to the safe defaults below.
TRAVEL_RAIL_CONNECTION_MATCHER_V2=true
TRAVEL_RAIL_MIN_TRANSFER_MINUTES=45
TRAVEL_RAIL_MAX_TRANSFER_WAIT_MINUTES=360

# 12306 official redirect only. No reverse engineering, login, order, or payment.
TRAVEL_SOURCE_RAIL_12306_REDIRECT_ENABLED=true
TRAVEL_SOURCE_RAIL_12306_REDIRECT_LICENSE_STATUS=APPROVED
TRAVEL_SOURCE_RAIL_12306_REDIRECT_QPS_LIMIT=1
TRAVEL_SOURCE_RAIL_12306_REDIRECT_COMMERCIAL_ALLOWED=false

# Airline official redirect only
TRAVEL_SOURCE_AIRLINE_OFFICIAL_REDIRECT_ENABLED=true
TRAVEL_SOURCE_AIRLINE_OFFICIAL_REDIRECT_LICENSE_STATUS=APPROVED
TRAVEL_SOURCE_AIRLINE_OFFICIAL_REDIRECT_QPS_LIMIT=1
TRAVEL_SOURCE_AIRLINE_OFFICIAL_REDIRECT_COMMERCIAL_ALLOWED=false

# Real LLM provider. If disabled, deterministic rules are used instead of an external LLM call.
TRAVEL_SOURCE_REAL_LLM_ENABLED=false
TRAVEL_SOURCE_REAL_LLM_LICENSE_STATUS=PENDING_REVIEW
TRAVEL_SOURCE_REAL_LLM_QPS_LIMIT=0
TRAVEL_SOURCE_REAL_LLM_COMMERCIAL_ALLOWED=false
OPENAI_API_KEY=
REAL_LLM_MODEL=gpt-4.1-mini
REAL_LLM_BASE_URL=https://api.openai.com/v1
REAL_LLM_TIMEOUT_SECONDS=45
REAL_LLM_MAX_TOKENS=800

# Return HTTP 200 + NO_MATCH with safe, explainable relaxation alternatives.
TRAVEL_CONSTRAINT_ANALYSIS_ENABLED=true
RESULT_SET_SEAT_PROPAGATION_ENABLED=true

# Optional live smoke parameters
LIVE_SMOKE_DEPARTURE_DATE=
LIVE_SMOKE_FLIGHT_ORIGIN=SHA
LIVE_SMOKE_FLIGHT_DESTINATION=TAO
LIVE_SMOKE_FLIGHT_MAX_RESULTS=3
LIVE_SMOKE_OPENSKY_LAMIN=45
LIVE_SMOKE_OPENSKY_LOMIN=5
LIVE_SMOKE_OPENSKY_LAMAX=55
LIVE_SMOKE_OPENSKY_LOMAX=15
LIVE_SMOKE_GEOCODE_QUERY=青岛栈桥
LIVE_SMOKE_GEOCODE_COUNTRY_CODES=cn
LIVE_SMOKE_GEOCODE_LIMIT=1
LIVE_SMOKE_WEATHER_LATITUDE=36.0662
LIVE_SMOKE_WEATHER_LONGITUDE=120.3826
LIVE_SMOKE_WEATHER_TIMEZONE=Asia/Shanghai
LIVE_SMOKE_RAIL_DEPARTURE_DATE=
LIVE_SMOKE_RAIL_TRAIN_NUMBER=
LIVE_SMOKE_RAIL_ORIGIN_STATION=上海虹桥
LIVE_SMOKE_RAIL_DESTINATION_STATION=北京南
